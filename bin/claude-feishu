#!/bin/bash
# Launch Claude Code with Feishu channel.
# Auto-resumes a session whose name ends with the current directory name.
# Falls back to the interactive session picker if no match is found.

CHANNEL_FLAG="--dangerously-load-development-channels plugin:feishu@feishu-local"
DIR_NAME=$(basename "$(pwd)")
PROJECT_KEY=$(pwd | sed 's|/|-|g')
PROJECT_DIR="$HOME/.claude/projects/$PROJECT_KEY"

# Prefer session named "cc_<dir>", fall back to any session ending with dir name
SEARCH=""
HAS_SESSIONS=0
if [ -d "$PROJECT_DIR" ] && compgen -G "$PROJECT_DIR/*.jsonl" > /dev/null; then
  HAS_SESSIONS=1
  if grep -rl "\"customTitle\":\"cc_${DIR_NAME}\"" "$PROJECT_DIR"/*.jsonl >/dev/null 2>&1; then
    SEARCH="cc_${DIR_NAME}"
  elif grep -rl "\"customTitle\":\".*${DIR_NAME}\"" "$PROJECT_DIR"/*.jsonl >/dev/null 2>&1; then
    SEARCH="$DIR_NAME"
  fi
fi

if [ -n "$SEARCH" ]; then
  exec claude --resume "$SEARCH" $CHANNEL_FLAG "$@"
elif [ "$HAS_SESSIONS" = "1" ]; then
  exec claude --resume $CHANNEL_FLAG "$@"
else
  exec claude $CHANNEL_FLAG "$@"
fi
